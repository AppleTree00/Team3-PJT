# a4u Web Application Environment Variables Example
# Copy this file to '.env' and fill in your actual API keys.

# Flask Application Settings
PORT=5000
SECRET_KEY=a4u-dev-secret-key-change-in-production

# Admin Settings
ADMIN_PASSWORD=admin1234

# AI Coaching Service Keys (Optional: Falls back to Mock mode if not provided)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
